# FlexOS XFCE Panel Config - Glassmorphism style
# Fichier: ~/.config/xfce4/panel/panels.rc

[Panel:1]
size=40
position-bottom=0
position-left=0
position-right=0
position-top=0
position=p=6;x=0;y=0
length=100
length-adjust=true
background-alpha=85
background-style=0
autohide-behavior=0
enter-opacity=1.0
leave-opacity=0.92
nrows=1

[Plugin:whiskermenu-1]
move-icon=true
show-button-title=true
show-button-border=false
show-description=true
show-tooltips=true
menu-icon=flexos-logo
menu-icon-size=22
button-title=Menu
button-icon=archlinux-logo
favorites=firefox.desktop,thunar.desktop,alacritty.desktop,xfce4-settings.desktop

[Plugin:tasklist-2]
show-labels=false
show-handle=false
show-tooltips=true
middle-click=close
grouping=0
sort-order=1
flat-buttons=true

[Plugin:separator-3]
style=0
expand=true

[Plugin:pulseaudio-4]
enable-menu-keys=true

[Plugin:clipman-5]
actions=

[Plugin:separator-6]
style=0

[Plugin:clock-7]
mode=0
show-frame=true
show-labels=true
time-format=%H:%M
date-format=%d/%m
tooltip-format=%A %d %B %Y
time-font=Cantarell Bold 12
date-font=Cantarell 9
clock-command=orage

[Plugin:systray-8]
size=22
symbolic-icons=true
show-frame=false
names=

[Panel:2]
position=p=10;x=0;y=0
size=50
background-alpha=0
background-style=0
autohide-behavior=0
nrows=1
length=100

[Plugin:genmon-9]
command=fastfetch --pipe
